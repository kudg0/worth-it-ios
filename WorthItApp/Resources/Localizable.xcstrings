    "\"%@\"" : {
      "comment" : "A text block that shows the user's notes for a trip. The text is automatically truncated if it doesn't fit.",
      "isCommentAutoGenerated" : true
    },
    "/ %@" : {
      "comment" : "A unit of measurement for mileage, such as \"km\".",
      "isCommentAutoGenerated" : true
    },
    "/%@" : {
      "comment" : "A unit of measurement, such as \"km\" or \"miles\", that appears after a cost per distance value.",
      "isCommentAutoGenerated" : true
    },
    "%@" : {
      "comment" : "A label that shows the number of events on a given day. The argument is the number of events on that day.",
      "isCommentAutoGenerated" : true
    },
    "%@ • %@" : {
      "comment" : "A line of text that shows the category and date of the expense.",
