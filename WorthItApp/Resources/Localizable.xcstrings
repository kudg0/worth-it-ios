      "comment" : "A label that shows the number of options that have been selected in a comparison view. The argument is the number of selected options.",
      "isCommentAutoGenerated" : true
    },
    "%@ spend" : {
      "comment" : "A label that reads \"spend\" in a compact size.",
      "isCommentAutoGenerated" : true
    },
